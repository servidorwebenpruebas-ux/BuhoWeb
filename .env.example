# --------------------------------------------------------------------------------------------------------------
# [ES] CONFIGURACIÓN DEL SERVIDOR | [EN] SERVER CONFIGURATION
# --------------------------------------------------------------------------------------------------------------
# [ES] Puerto donde funcionará la aplicación (Por defecto 3000)
# [EN] Port where the application will run (Default 3000)
PORT=3000

# --------------------------------------------------------------------------------------------------------------
# [ES] SEGURIDAD Y AUTENTICACIÓN| [EN] SECURITY AND AUTHENTICATION
# --------------------------------------------------------------------------------------------------------------
# [ES] Clave secreta para la firma de los tokens de sesión (JWT)
# [EN] Secret key for signing session tokens (JWT)
JWT_SECRET=escribe_aqui_una_clave_aleatoria_y_larga

# --------------------------------------------------------------------------------------------------------------
# [ES] CONFIGURACIÓN DE BASE DE DATOS | [EN] DATABASE CONFIGURATION
# --------------------------------------------------------------------------------------------------------------
# [ES] Ruta del archivo SQLite para persistencia de datos
# [EN] Path to the SQLite file for data persistence
DB_PATH=./data/buhoweb.sqlite

# --------------------------------------------------------------------------------------------------------------
# [ES] CONFIGURACIÓN SMTP (ENVÍO DE CORREOS) | [EN] SMTP CONFIGURATION (EMAIL SENDING)
# --------------------------------------------------------------------------------------------------------------
# [ES] SMTP_HOST: Poner el host SMTP de tu proveedor de correo (ej. smtp.gmail.com para Gmail)
# [EN] SMTP_HOST: Set the SMTP host of your email provider (e.g., smtp.gmail.com for Gmail)
SMTP_HOST=smtp.ejemplo.com
# [ES] SMTP_PORT: Poner el puerto SMTP (465 para SSL o 587 para TLS/STARTTLS)
# [EN] SMTP_PORT: Set the SMTP port (465 for SSL or 587 for TLS/STARTTLS)
SMTP_PORT=465
# [ES] SMTP_SECURE: poner 'true' para puerto 465 (SSL) o 'false' para puerto 587 (TLS/STARTTLS)
# [EN] SMTP_SECURE: set 'true' for port 465 (SSL) or 'false' for port 587 (TLS/STARTTLS)
SMTP_SECURE=true
# [ES] SMTP_USER: Poner la dirección comlpeta de correo electrónico utilizada para enviar los correos
# [EN] SMTP_USER: Set the full email address used to send emails
SMTP_USER=tu-correo@dominio.com
# [ES] SMTP_PASS: Poner la contraseña o clave de aplicación del correo utilizado para enviar los correos
# [EN] SMTP_PASS: Set the password or application key of the email used to send emails
SMTP_PASS=tu-clave-de-aplicacion

# --------------------------------------------------------------------------------------------------------------
# [ES] PERSONALIZACIÓN DE CORREOS (SOPORTA PLACEHOLDERS) | [EN] EMAIL CUSTOMIZATION (SUPPORTS PLACEHOLDERS)
# --------------------------------------------------------------------------------------------------------------
# [ES] Registro (Placeholder: %CODIGO%): Correo para nuevos usuarios con el código de confirmación de registro
# [EN] Registration (Placeholder: %CODE%): Email for new users with the registration confirmation code
ASUNTO_REGISTRO= BuhoWeb: Código de activación
TEXTO_REGISTRO=¡Bienvenido! Tu código para activar la cuenta es: %CODIGO%

# [ES] Alerta de caída (Placeholder: %SITIO% y %URL%): Correo de alerta cuando se detecta que un sitio web ha dejado de responder
# [EN] Downtime Alert (Placeholder: %SITIO% and %URL%): Alert email when a website is detected as unresponsive
ASUNTO_ALERTA= ALERTA: Caída de servicio detectada
TEXTO_ALERTA=El sistema BuhoWeb informa que el sitio web %SITIO% (%URL%) ha dejado de responder.

# [ES] Recuperación (Placeholder: %CLAVE%): Correo para recuperación de acceso con contraseña temporal
# [EN] Recovery (Placeholder: %CLAVE%): Email for access recovery with temporary password
ASUNTO_RECUPERAR= BuhoWeb: Recuperación de acceso
TEXTO_RECUPERAR=Se ha solicitado el desbloqueo de tu cuenta. Tu contraseña temporal es: %CLAVE%. Por favor, cámbiala al entrar.
